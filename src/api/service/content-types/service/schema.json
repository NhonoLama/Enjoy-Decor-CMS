{
  "kind": "collectionType",
  "collectionName": "services",
  "info": {
    "singularName": "service",
    "pluralName": "services",
    "displayName": "Service"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "number": {
      "type": "integer",
      "required": true,
      "min": 1,
      "max": 6
    },
    "title": {
      "type": "string",
      "required": true
    },
    "tagline": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "img": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "icon": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "detail_list": {
      "type": "component",
      "component": "service.service-detail-list",
      "repeatable": true
    }
  }
}
