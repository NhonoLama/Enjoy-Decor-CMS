{
  "kind": "singleType",
  "collectionName": "company_infos",
  "info": {
    "singularName": "company-info",
    "pluralName": "company-infos",
    "displayName": "Company Info"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "location": {
      "type": "string",
      "minLength": 2,
      "maxLength": 40,
      "required": true
    },
    "email": {
      "type": "email",
      "required": false
    },
    "phone_number": {
      "type": "string",
      "minLength": 10,
      "maxLength": 15,
      "required": true
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "location_link": {
      "type": "string"
    }
  }
}
