{
  "kind": "collectionType",
  "collectionName": "offices",
  "info": {
    "singularName": "office",
    "pluralName": "offices",
    "displayName": "Office"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "city": {
      "type": "string",
      "required": true
    },
    "country": {
      "type": "string",
      "minLength": 1,
      "maxLength": 20,
      "required": true
    },
    "address": {
      "type": "string"
    },
    "phone": {
      "type": "string",
      "minLength": 10,
      "maxLength": 13,
      "required": true
    },
    "email": {
      "type": "email",
      "required": true
    },
    "hours": {
      "type": "string",
      "default": "Sun – Fri, 9am – 6pm NPT"
    },
    "isHQ": {
      "type": "boolean",
      "required": true
    },
    "order": {
      "type": "integer"
    },
    "location_link": {
      "type": "string"
    }
  }
}
