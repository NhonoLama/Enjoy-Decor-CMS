{
  "kind": "collectionType",
  "collectionName": "team_members",
  "info": {
    "singularName": "team-member",
    "pluralName": "team-members",
    "displayName": "Team Member"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "full_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 20,
      "required": true
    },
    "role": {
      "type": "string",
      "default": "Architect",
      "minLength": 1,
      "maxLength": 20,
      "required": true
    },
    "bio": {
      "type": "text",
      "minLength": 5,
      "maxLength": 50,
      "required": true
    },
    "profile_pic": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "specialty": {
      "type": "string"
    },
    "order": {
      "type": "integer",
      "required": true,
      "unique": false,
      "min": 1,
      "max": 10
    }
  }
}
