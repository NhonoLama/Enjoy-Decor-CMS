{
  "kind": "collectionType",
  "collectionName": "catalogs",
  "info": {
    "singularName": "catalog",
    "pluralName": "catalogs",
    "displayName": "Catalog"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "required": true
    },
    "count": {
      "type": "integer",
      "required": true,
      "default": 1
    },
    "cover_img": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "order": {
      "type": "integer",
      "unique": true
    },
    "projects": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::project.project",
      "mappedBy": "catalog"
    }
  }
}
